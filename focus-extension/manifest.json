{
    "manifest_version": 3,
    "name": "YouTube Focus Study Player",
    "version": "1.0.0",
    "description": "Stay focused while studying with YouTube. Lock yourself to a single video or playlist during study sessions with a built-in Pomodoro timer. Blocks distracting YouTube browsing until your session is complete.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "tabs",
        "webNavigation"
    ],
    "host_permissions": [
        "*://*.youtube.com/*",
        "https://youtube-focus-study-private.vercel.app/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png"
        },
        "default_title": "YouTube Focus Study Player"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://youtube-focus-study-private.vercel.app/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}